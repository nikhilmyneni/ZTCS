# ─── Server Configuration ───
PORT=5000
NODE_ENV=development

# ─── MongoDB Atlas ───
# Go to: https://cloud.mongodb.com → Create Cluster → Get Connection String
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/ztcs?retryWrites=true&w=majority

# ─── Redis (Upstash) ───
# Go to: https://console.upstash.com → Create Database → Get REST URL
REDIS_URL=rediss://default:<password>@<endpoint>.upstash.io:6379

# ─── JWT Secrets ───
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your-super-secret-jwt-key-change-this
JWT_REFRESH_SECRET=your-refresh-secret-key-change-this
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ─── UEBA Service ───
UEBA_SERVICE_URL=http://localhost:8000
# Shared secret for service-to-service auth (must match ueba-service/.env)
# Leave empty to disable (dev only)
UEBA_SERVICE_TOKEN=

# ─── Email (Nodemailer — Gmail App Password) ───
# Go to: Google Account → Security → 2FA → App Passwords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-gmail-app-password
ALERT_EMAIL=admin@yourdomain.com

# ─── Supabase Storage ───
# Go to: https://supabase.com → Create Project → Settings → API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key
SUPABASE_BUCKET=ztcs-files

# ─── File Encryption ───
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# If not set, files will be stored unencrypted
ENCRYPTION_MASTER_KEY=

# ─── Gemini AI (Zero Chatbot) ───
# Go to: https://aistudio.google.com/apikey → Create API Key
GEMINI_API_KEY=

# ─── Client URL (CORS) ───
CLIENT_URL=http://localhost:5173
