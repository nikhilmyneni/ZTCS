# ─── UEBA Service Config ───
PORT=8000
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/ztcs?retryWrites=true&w=majority

# ─── Service-to-Service Auth ───
# Shared secret between Node.js backend and UEBA service
# Must match UEBA_SERVICE_TOKEN in server/.env
# Leave empty to disable auth (dev only)
UEBA_SERVICE_TOKEN=

# ─── ipinfo.io API (OPTIONAL) ───
# Go to: https://ipinfo.io/signup → Get free token (50k requests/month)
# Works without token (rate-limited to ~1000 req/day)
# Set to "skip-for-now" to use without token
IPINFO_TOKEN=skip-for-now
